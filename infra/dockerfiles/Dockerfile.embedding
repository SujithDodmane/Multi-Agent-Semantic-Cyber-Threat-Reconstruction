FROM nvidia/cuda:12.4.0-runtime-ubuntu22.04

RUN apt-get update && apt-get install -y python3.10 python3-pip && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY services/embedding/requirements.txt /app/services/embedding/requirements.txt
RUN pip install --no-cache-dir -r services/embedding/requirements.txt

COPY services/embedding/ /app/services/embedding/
COPY schemas/ /app/schemas/

EXPOSE 8001

CMD ["uvicorn", "services.embedding.app:app", "--host", "0.0.0.0", "--port", "8001"]
