FROM python:3.10-slim

WORKDIR /app

COPY services/graph/requirements.txt /app/services/graph/requirements.txt
RUN pip install --no-cache-dir -r services/graph/requirements.txt

COPY services/graph/ /app/services/graph/
COPY schemas/ /app/schemas/

EXPOSE 5000 5001

CMD ["python", "-m", "services.graph.server"]
