# ==============================================================================
# AEGIS — Environment Configuration Template
# Copy this to .env and fill in your values
# ==============================================================================

# --- Notification Services ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here

# --- Ollama / LLM ---
OLLAMA_BASE_URL=http://localhost:11434
QWEN_MODEL_NAME=qwen2.5:7b-instruct-q4_K_M

# --- Embedding Service ---
EMBEDDING_SERVICE_URL=http://localhost:8001
BGE_MODEL_NAME=BAAI/bge-m3
EMBEDDING_BATCH_WINDOW_MS=50
EMBEDDING_MAX_TOKENS=512

# --- ChromaDB ---
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_PERSIST_DIR=./data/chromadb

# --- SQLite ---
SQLITE_DB_PATH=./data/aegis.db

# --- Ingestion ---
LOG_WATCH_DIRS=./logs
CURSOR_PERSIST_DIR=./data/cursors

# --- Queue ---
QUEUE_MAX_DEPTH=50

# --- Correlation ---
SIMILARITY_THRESHOLD=0.72
TEMPORAL_WINDOW_HOURS=2
HNSW_EF_CONSTRUCTION=200
HNSW_M=48

# --- Circuit Breaker ---
CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT=60

# --- Dead Letter Queue ---
DLQ_RETRY_INTERVAL_MINUTES=5
DLQ_MAX_RETRIES=3

# --- Graph UI ---
GRAPH_UI_PORT=5000
WEBSOCKET_PORT=5001
