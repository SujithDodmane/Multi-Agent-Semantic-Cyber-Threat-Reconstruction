{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TriageOutput",
  "description": "Output schema for the Triage SKILL.md",
  "type": "object",
  "required": ["anomaly_detected", "severity", "heuristic_flags", "correlation_required", "confidence"],
  "properties": {
    "anomaly_detected": { "type": "boolean" },
    "severity": { "type": "string", "enum": ["P0", "P1", "P2", "BENIGN"] },
    "heuristic_flags": { "type": "array", "items": { "type": "string" } },
    "correlation_required": { "type": "boolean" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
