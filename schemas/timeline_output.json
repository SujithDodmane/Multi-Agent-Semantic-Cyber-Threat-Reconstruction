{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TimelineOutput",
  "description": "Output schema for the Timeline SKILL.md — also the forensic report schema",
  "type": "object",
  "required": ["narrative", "confidence", "mitre_tactics", "mitre_techniques", "entities", "timeline_events", "root_cause", "report_id"],
  "properties": {
    "narrative": { "type": "string", "description": "Human-readable forensic narrative" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "mitre_tactics": { "type": "array", "items": { "type": "string" } },
    "mitre_techniques": { "type": "array", "items": { "type": "string" } },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["ip", "hostname", "process", "user", "file"] },
          "value": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    },
    "timeline_events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "description": { "type": "string" },
          "severity": { "type": "string" },
          "log_uuid": { "type": "string", "format": "uuid" }
        }
      }
    },
    "root_cause": { "type": "string" },
    "report_id": { "type": "string", "format": "uuid" }
  }
}
